type HttpResponse = 
 record {
   body: blob;
   headers: vec HttpHeader;
   status: nat;
 };
type HttpHeader = 
 record {
   name: text;
   value: text;
 };
service : {
  fetch_injuries: () -> (text);
  fetch_live_props: () -> (text);
  get_agent_stats: () -> (text) query;
  get_best_4_pick: () -> (text);
  get_best_5_pick: () -> (text);
  get_best_6_pick: () -> (text);
  get_best_slip: (n: nat) -> (text);
  get_injury_cache: () -> (text) query;
  get_last_slip: () -> (text) query;
  get_live_props: () -> (text) query;
  get_ranked_props: () -> (text) query;
  refresh_data: () -> (text);
  register_on_agentforge: () -> (text);
  transform: (raw: record {
                     context: blob;
                     response: HttpResponse;
                   }) -> (HttpResponse) query;
}
